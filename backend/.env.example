# Caddy will request and renew HTTPS certificates for this domain.
API_DOMAIN=api.example.com

# Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_DEBUG=false

# Comma-separated API hostnames Django is allowed to serve.
DJANGO_ALLOWED_HOSTS=api.example.com

# Comma-separated frontend origins allowed to call the API.
# Example: https://gooseduckgoose.example.com,https://meowintelligence.github.io
CORS_ALLOWED_ORIGINS=https://gooseduckgoose.example.com

# Optional Gunicorn tuning.
GUNICORN_WORKERS=2
